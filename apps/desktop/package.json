{
  "name": "@dawning/desktop",
  "private": true,
  "version": "0.0.1",
  "description": "Dawning Agent OS desktop shell — Electron main process + .NET Api supervisor (ADR-025).",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "pnpm run build:preload && tsx src/main.ts",
    "smoke": "pnpm run build:preload && tsx scripts/smoke.ts",
    "build:preload": "tsc -p tsconfig.preload.json && node -e \"const fs=require('node:fs');fs.rmSync('dist/preload.cjs.js',{force:true});fs.renameSync('dist/preload.js','dist/preload.cjs.js')\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^33.2.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3"
  }
}
